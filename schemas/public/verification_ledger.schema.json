{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TradingMapClaw public verification ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "content_id", "content_type", "period", "data_as_of", "published_date", "title", "summary", "items", "verification", "status", "compliance"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "content_id": {"type": "string", "pattern": "^verification-ledger-[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "content_type": {"type": "string", "const": "VERIFICATION_LEDGER"},
    "period": {"type": "string", "minLength": 3, "maxLength": 40},
    "data_as_of": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "published_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 8, "maxLength": 120},
    "summary": {"type": "string", "minLength": 30, "maxLength": 800},
    "items": {
      "type": "array", "minItems": 1, "maxItems": 12,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["subject", "research_question", "maker_view", "checker_view", "resolution", "evidence_for", "evidence_against", "source_urls"],
        "properties": {
          "subject": {"type": "string", "minLength": 2, "maxLength": 80},
          "research_question": {"type": "string", "minLength": 12, "maxLength": 240},
          "maker_view": {"type": "string", "minLength": 8, "maxLength": 360},
          "checker_view": {"type": "string", "minLength": 8, "maxLength": 360},
          "resolution": {"type": "string", "enum": ["AGREEMENT", "OPEN_QUESTION", "DATA_UNAVAILABLE", "METHOD_REVISED"]},
          "evidence_for": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string", "minLength": 5, "maxLength": 240}},
          "evidence_against": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string", "minLength": 5, "maxLength": 240}},
          "source_urls": {"type": "array", "minItems": 2, "maxItems": 8, "items": {"type": "string", "pattern": "^https://"}}
        }
      }
    },
    "verification": {
      "type": "object", "additionalProperties": false,
      "required": ["hermes", "codex"],
      "properties": {
        "hermes": {"type": "string", "const": "PASS"},
        "codex": {"type": "string", "const": "PASS"}
      }
    },
    "status": {"type": "string", "const": "APPROVED_CANDIDATE"},
    "compliance": {"type": "string", "const": "WATCHLIST_ONLY"}
  }
}
