{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TradingMapClaw public system update",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "content_id", "content_type", "published_date", "title", "summary", "changes", "evidence", "status", "compliance"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "content_id": {"type": "string", "pattern": "^build-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"},
    "content_type": {"type": "string", "const": "SYSTEM_BUILD_LOG"},
    "published_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 8, "maxLength": 120},
    "summary": {"type": "string", "minLength": 20, "maxLength": 600},
    "changes": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "minLength": 8, "maxLength": 300}},
    "evidence": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "minLength": 3, "maxLength": 240}},
    "status": {"type": "string", "const": "APPROVED"},
    "compliance": {"type": "string", "const": "WATCHLIST_ONLY"}
  }
}
